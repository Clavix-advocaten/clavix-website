---
interface Props {
  heading?: string
  description?: string
  variant?: 'primary' | 'secondary'
}

const {
  heading = 'Plan een eerste gesprek',
  description = 'We luisteren naar uw situatie en geven aan of, en hoe, wij u kunnen bijstaan.',
  variant = 'primary',
} = Astro.props

const bgClass = variant === 'primary' ? 'bg-bg-inverse text-text-inverse' : 'bg-bg-tinted text-text'
---

<section id="contact" class={`${bgClass} py-16 mt-0`}>
  <div class="max-w-content mx-auto px-4 md:px-8 text-center">
    <h2 class="text-h2 font-bold mb-4" style="color: var(--neutral-0);">{heading}</h2>
    <p class="text-lead opacity-90 mb-8 max-w-2xl mx-auto" style="color: var(--ns-100);">
      {description}
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a
        href="mailto:kumar@clavix.nl?subject=Eerste gesprek"
        class="bg-action text-action-fg hover:bg-action-hover px-8 py-4 rounded-md font-semibold no-underline transition inline-block"
      >
        Plan een eerste gesprek
      </a>
      <a
        href="tel:+31207471121"
        class="bg-action-secondary text-action-secondary-fg hover:bg-action-secondary-hover px-8 py-4 rounded-md font-semibold no-underline transition inline-block"
      >
        Bel: +31 20 747 1121
      </a>
    </div>
  </div>
</section>
