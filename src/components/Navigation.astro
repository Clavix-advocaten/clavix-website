---
/**
 * Top navigation — sticky on scroll, met mega-menu voor praktijkgebieden.
 */

const navItems: any[] = [
  {
    label: 'Expertise',
    href: '#',
    mega: true,
    columns: [
      {
        heading: 'Praktijkgebieden',
        items: [
          { label: 'Vastgoed × Ondernemers', href: '/praktijkgebieden/vastgoed-en-ondernemers', sub: 'Vastgoedvraagstukken voor ondernemers' },
          { label: 'Ondernemingsrecht', href: '/praktijkgebieden/ondernemingsrecht', sub: 'BV-structuren en aandeelhouders' },
          { label: 'Vastgoedrecht', href: '/praktijkgebieden/vastgoedrecht', sub: 'Huur, koop, en eigendom' },
          { label: 'Insolventie & herstructurering', href: '/praktijkgebieden/insolventie-en-herstructurering', sub: 'Faillissement, WHOA, doorstart' },
        ],
      },
      {
        heading: 'Specialisaties',
        items: [
          { label: 'Aandeelhoudersgeschillen', href: '/specialisme/aandeelhoudersgeschillen', sub: '50/50-patstellingen tot uitkoop' },
          { label: 'Bedrijfsoverdracht met vastgoed', href: '/specialisme/bedrijfsoverdracht-met-vastgoed', sub: 'M&A waar het pand onderdeel is' },
          { label: 'Bestuurdersaansprakelijkheid', href: '/specialisme/bestuurdersaansprakelijkheid', sub: 'Verdediging en preventief advies' },
          { label: 'Bouwgeschillen', href: '/specialisme/bouwgeschillen', sub: 'Wanprestatie en gebreken' },
        ],
      },
    ],
  },
  { label: 'Werkwijze', href: '/werkwijze' },
  { label: 'mr. Kumar', href: '/mukesh' },
  { label: 'Notities', href: '/notities' },
  { label: 'Sectoren', href: '/sectoren' },
  { label: 'Veelgestelde vragen', href: '/veelgestelde-vragen' },
  { label: 'Contact', href: '/contact' },
]
---

<header class="sticky top-0 z-50 bg-bg/95 backdrop-blur-md border-b border-border">
  <nav class="max-w-container mx-auto px-4 md:px-8 py-4 flex items-center justify-between">
    {/* Logo */}
    <a href="/" class="block no-underline" aria-label="Clavix — naar homepage">
      <img src="/clavix-logo.svg" alt="Clavix" class="h-9 w-auto" width="180" height="36" />
    </a>

    {/* Desktop nav */}
    <ul class="hidden md:flex items-center gap-8 text-small">
      {navItems.map((item: any) => (
        <li class="relative group">
          {item.mega ? (
            <>
              <button
                data-dropdown-trigger
                class="text-text hover:text-text-accent transition flex items-center gap-1 py-2"
                aria-haspopup="true"
              >
                {item.label}
                <svg class="w-3 h-3" viewBox="0 0 12 12" fill="currentColor"><path d="M6 8L2 4h8z"/></svg>
              </button>
              <div data-dropdown class="absolute top-full left-0 mt-2 bg-bg-elevated border border-border rounded-lg shadow-lg p-6 min-w-[640px] grid grid-cols-2 gap-6 opacity-0 invisible transition pointer-events-none">
                {item.columns.map((col: any) => (
                  <div>
                    <div class="text-tiny font-mono uppercase tracking-wider text-text-muted mb-3 pb-2 border-b border-border">
                      {col.heading}
                    </div>
                    <ul class="space-y-1">
                      {col.items.map((child: any) => (
                        <li>
                          <a href={child.href} class="block px-2 py-2 text-text hover:bg-bg-tinted rounded-md no-underline">
                            <div class="font-medium">{child.label}</div>
                            {child.sub && <div class="text-tiny text-text-muted mt-0.5">{child.sub}</div>}
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                ))}
              </div>
            </>
          ) : (
            <a href={item.href} class="text-text hover:text-text-accent transition no-underline">
              {item.label}
            </a>
          )}
        </li>
      ))}
    </ul>

    {/* Search button */}
    <button
      data-search-open
      class="hidden md:flex items-center justify-center w-10 h-10 text-text hover:text-text-accent transition"
      aria-label="Zoeken openen (Cmd+K)"
      title="Zoeken (Cmd+K)"
    >
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
      </svg>
    </button>

    {/* CTA */}
    <a
      href="/contact"
      class="hidden md:inline-block bg-action text-action-fg hover:bg-action-hover px-5 py-2.5 rounded-md font-semibold text-small no-underline transition"
    >
      Plan een gesprek
    </a>

    {/* Mobile search button */}
    <button
      data-search-open
      class="md:hidden p-2 text-text"
      aria-label="Zoeken openen"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
      </svg>
    </button>

    {/* Mobile menu button */}
    <button
      id="mobile-menu-toggle"
      class="md:hidden p-2"
      aria-label="Menu openen"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

{/* Search modal — Cmd+K, ESC, / */}
<div
  id="search-modal"
  class="fixed inset-0 z-50 hidden items-start justify-center pt-20 px-4"
  role="dialog"
  aria-modal="true"
  aria-labelledby="search-modal-title"
>
  <div data-search-backdrop class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>
  <div class="relative bg-bg-elevated border border-border rounded-lg shadow-2xl w-full max-w-2xl max-h-[80vh] overflow-hidden flex flex-col">
    <div class="flex items-center justify-between p-4 border-b border-border">
      <h2 id="search-modal-title" class="text-h4 font-semibold text-text">Zoeken in Clavix</h2>
      <button data-search-close class="text-text-secondary hover:text-text transition p-1" aria-label="Sluiten">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
    <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />
    <div class="p-4 overflow-y-auto">
      <div id="search-modal-input"></div>
    </div>
    <div class="px-4 py-2 border-t border-border bg-bg-tinted text-tiny text-text-muted flex flex-wrap gap-3">
      <span>Tip:</span>
      <span><kbd class="px-1.5 py-0.5 bg-bg-elevated border border-border rounded font-mono">Cmd K</kbd> openen</span>
      <span><kbd class="px-1.5 py-0.5 bg-bg-elevated border border-border rounded font-mono">/</kbd> snelzoeken</span>
      <span><kbd class="px-1.5 py-0.5 bg-bg-elevated border border-border rounded font-mono">Esc</kbd> sluiten</span>
    </div>
  </div>
</div>

<script src="/pagefind/pagefind-ui.js" is:inline></script>
<script is:inline>
  (function() {
    const modal = document.getElementById('search-modal');
    if (!modal) return;
    const openBtns = document.querySelectorAll('[data-search-open]');
    const closeBtns = modal.querySelectorAll('[data-search-close]');
    const backdrop = modal.querySelector('[data-search-backdrop]');
    let pagefindInited = false;

    function openModal() {
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      document.body.style.overflow = 'hidden';
      if (!pagefindInited && typeof PagefindUI !== 'undefined') {
        new PagefindUI({
          element: '#search-modal-input',
          showSubResults: true,
          showImages: false,
          resetStyles: false,
          translations: {
            placeholder: 'Zoek in artikelen, woorden, vragen...',
            clear_search: 'Wissen',
            load_more: 'Meer resultaten',
            search_label: 'Zoeken bij Clavix',
            zero_results: 'Geen resultaten voor [SEARCH_TERM]',
            many_results: '[COUNT] resultaten voor [SEARCH_TERM]',
            one_result: '1 resultaat voor [SEARCH_TERM]',
            alt_search: 'Geen resultaten voor [SEARCH_TERM]. Resultaten voor [DIFFERENT_TERM]:',
            search_suggestion: 'Geen resultaten. Probeer: [DIFFERENT_TERM]',
            searching: 'Zoeken...'
          }
        });
        pagefindInited = true;
      }
      setTimeout(() => {
        const input = modal.querySelector('input[type="text"]');
        if (input) input.focus();
      }, 60);
    }

    function closeModal() {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      document.body.style.overflow = '';
    }

    openBtns.forEach(b => b.addEventListener('click', openModal));
    closeBtns.forEach(b => b.addEventListener('click', closeModal));
    backdrop && backdrop.addEventListener('click', closeModal);

    document.addEventListener('keydown', (e) => {
      const isInput = ['INPUT','TEXTAREA'].includes(document.activeElement?.tagName);
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        openModal();
      } else if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
        closeModal();
      } else if (e.key === '/' && !isInput && modal.classList.contains('hidden')) {
        e.preventDefault();
        openModal();
      }
    });
  })();
</script>


  {/* Mobile menu */}
  <div id="mobile-menu" class="hidden md:hidden bg-bg-elevated border-t border-border">
    <ul class="px-4 py-4 space-y-3">
      {navItems.map((item: any) => (
        <li>
          {item.mega ? (
            <>
              <div class="font-medium text-text py-2">{item.label}</div>
              {item.columns.map((col: any) => (
                <div class="mt-2">
                  <div class="text-tiny font-mono uppercase tracking-wider text-text-muted py-1">{col.heading}</div>
                  <ul class="pl-2 space-y-1 mt-1">
                    {col.items.map((child: any) => (
                      <li>
                        <a href={child.href} class="block py-1 text-text-secondary text-small no-underline">{child.label}</a>
                      </li>
                    ))}
                  </ul>
                </div>
              ))}
            </>
          ) : (
            <a href={item.href} class="block py-2 text-text no-underline">{item.label}</a>
          )}
        </li>
      ))}
      <li>
        <a
          href="/contact"
          class="block bg-action text-action-fg text-center px-5 py-3 rounded-md font-semibold mt-4 no-underline"
        >
          Plan een gesprek
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const toggle = document.getElementById('mobile-menu-toggle')
  const menu = document.getElementById('mobile-menu')
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden')
  })
</script>

<script>
  // Dropdown hover-bridge met 250ms vertraging op sluiten
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('[data-dropdown-trigger]').forEach((trigger) => {
      const parentLi = trigger.closest('li');
      if (!parentLi) return;
      const dropdown = parentLi.querySelector('[data-dropdown]');
      if (!dropdown) return;
      let closeTimer: any = null;
      const open = () => {
        if (closeTimer) { clearTimeout(closeTimer); closeTimer = null; }
        dropdown.classList.remove('opacity-0', 'invisible', 'pointer-events-none');
        dropdown.classList.add('opacity-100', 'visible');
      };
      const scheduleClose = () => {
        if (closeTimer) clearTimeout(closeTimer);
        closeTimer = setTimeout(() => {
          dropdown.classList.add('opacity-0', 'invisible', 'pointer-events-none');
          dropdown.classList.remove('opacity-100', 'visible');
        }, 250);
      };
      parentLi.addEventListener('mouseenter', open);
      parentLi.addEventListener('mouseleave', scheduleClose);
      dropdown.addEventListener('mouseenter', open);
      dropdown.addEventListener('mouseleave', scheduleClose);
    });
  });
</script>
