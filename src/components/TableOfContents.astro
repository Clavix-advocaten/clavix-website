---
const { sections } = Astro.props;

const items = (sections || [])
  .map((s) => ({
    heading: s.heading,
    slug: typeof s.anchor === 'string' ? s.anchor : s.anchor?.current,
  }))
  .filter((i) => i.heading && i.slug);
---

{items.length > 0 && (
  <nav class="lg:sticky lg:top-24" aria-label="Inhoudsopgave">
    <p class="text-tiny font-mono uppercase tracking-wider text-text-secondary font-semibold mb-3">
      Op deze pagina
    </p>
    <ol class="m-0 p-0 flex flex-col gap-1.5 list-none">
      {items.map((item) => (
        <li>
          <a
            href={`#${item.slug}`}
            class="toc-link block pl-3 border-l-2 border-transparent text-text-secondary text-tiny leading-snug hover:text-text hover:border-border no-underline transition-colors"
          >
            {item.heading}
          </a>
        </li>
      ))}
    </ol>
  </nav>
)}

<style>
  .toc-link.is-active {
    border-left-color: #B08D57;
    color: #0A1628;
    font-weight: 500;
  }
</style>

<script>
  (function initTOC() {
    const links = document.querySelectorAll('.toc-link');
    if (!links.length) return;
    const sections = [];
    const linkMap = {};
    links.forEach((l) => {
      const href = l.getAttribute('href');
      if (!href || !href.startsWith('#')) return;
      const id = href.slice(1);
      const el = document.getElementById(id);
      if (el) {
        sections.push(el);
        linkMap[id] = l;
      }
    });
    if (!sections.length) return;
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            links.forEach((l) => l.classList.remove('is-active'));
            if (linkMap[entry.target.id]) linkMap[entry.target.id].classList.add('is-active');
          }
        });
      },
      { rootMargin: '-25% 0px -60% 0px', threshold: 0 }
    );
    sections.forEach((s) => observer.observe(s));
  })();
</script>

