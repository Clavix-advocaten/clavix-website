---
const { sections } = Astro.props;

const items = (sections || [])
  .map((s) => ({
    heading: s.heading,
    slug: typeof s.anchor === 'string' ? s.anchor : s.anchor?.current,
  }))
  .filter((i) => i.heading && i.slug);
---

{items.length > 0 && (
  <nav class="lg:sticky lg:top-24" aria-label="Inhoudsopgave">
    <p class="text-tiny font-mono uppercase tracking-wider text-text-secondary font-semibold mb-3">
      Op deze pagina
    </p>
    <ol class="m-0 p-0 flex flex-col gap-2 list-none">
      {items.map((item) => (
        <li>
          
            href={`#${item.slug}`}
            class="block pl-3 border-l-2 border-transparent text-text-secondary text-small leading-snug hover:text-text hover:border-border no-underline transition-colors"
          >
            {item.heading}
          </a>
        </li>
      ))}
    </ol>
  </nav>
)}
