---
import BaseLayout from '@layouts/BaseLayout.astro'
import CTABand from '@components/CTABand.astro'
import AnswerCapsule from '@components/AnswerCapsule.astro'
import TLDR from '@components/TLDR.astro'
import FAQAccordion from '@components/FAQAccordion.astro'
import { getClusterPage, getAllClusterSlugs } from '@lib/queries'
import { renderPortableText } from '@lib/portable-text'
import { articleSchema, faqPageSchema, breadcrumbSchema } from '@lib/schema-markup'

export async function getStaticPaths() {
  const slugs = await getAllClusterSlugs().catch(() => [])
  return slugs.map((s: any) => ({ params: { slug: s.slug } }))
}

const { slug } = Astro.params
const cluster = await getClusterPage(slug as string)

if (!cluster) return Astro.redirect('/404')

const breadcrumbs = [
  { name: 'Home', url: '/' },
]
if (cluster.parentPillar) {
  breadcrumbs.push({ name: cluster.parentPillar.shortTitle, url: `/praktijkgebieden/${cluster.parentPillar.slug}` })
}
breadcrumbs.push({ name: cluster.title, url: `/clusters/${slug}` })

const schemas: any[] = [
  articleSchema(cluster, cluster.author?.name || 'mr. Mukesh Kumar'),
  breadcrumbSchema(breadcrumbs),
]

if (cluster.faqs && cluster.faqs.length > 0) {
  const fp = faqPageSchema(cluster.faqs)
  if (fp) schemas.push(fp)
}

// === HowTo schema voor procedurele clusters ===
const HOWTO_STEPS: Record<string, string[]> = {
  '50-50-aandeelhoudersgeschil-oplossen': [
    'Beoordeel of mediation een werkbare uitweg biedt',
    'Onderzoek de shotgun-clausule in de aandeelhoudersovereenkomst',
    'Overweeg een geschillenregeling-procedure (2:336-343 BW)',
    'Bereid in laatste instantie een uitkoopprocedure voor',
  ],
  'activatransactie-faillissement': [
    'Verken haalbaarheid van een doorstart met het management',
    'Stel een onderhandelingsmemo op voor de curator',
    'Onderhandel over koopprijs, activa en personeel-overname',
    'Houd rekening met het Smallsteps-arrest bij personele overgang',
    'Sluit de notariele activatransactie-overeenkomst',
  ],
  'beslag-op-aandelen': [
    'Toets of er een gegrond vorderingsrecht aanwezig is',
    'Vraag verlof bij de voorzieningenrechter (artikel 700 Rv)',
    'Laat beslag formeel betekenen aan vennootschap en aandeelhouder',
    'Procedeer over de hoofdvordering ter validatie',
  ],
  'pre-pack-doorstart': [
    'Beoordeel financiele positie en doorstart-kansen',
    'Identificeer een serieuze overnemende partij',
    'Dien beoogd-curator-verzoek in bij de rechtbank',
    'Onderhandel concept-activatransactie in vertrouwen',
    'Vraag formeel faillissement aan',
    'Sluit de doorstart binnen 24-48 uur',
  ],
  'statuten-bv-wijzigen': [
    'Bepaal welke wijzigingen u wilt doorvoeren',
    'Roep een algemene vergadering van aandeelhouders bijeen',
    'Neem het wijzigingsbesluit met vereiste meerderheid',
    'Laat een notaris de akte van statutenwijziging opmaken',
    'Schrijf de gewijzigde statuten in bij de KvK',
  ],
  'verzet-tegen-faillissement': [
    'Beoordeel binnen 14 dagen of verzet kansrijk is',
    'Stel verzetschrift op bij de rechtbank',
    'Bereid verweer voor: pluraliteit, opeisbaarheid, betalingsonmacht',
    'Voer behandeling ter zitting',
    'Vraag vernietiging van het faillissementsvonnis',
  ],
  'whoa-traject-ondernemer-kosten-kansen': [
    'Verken financiele haalbaarheid van een WHOA-akkoord',
    'Stel het herstructureringsplan op met klassen-indeling',
    'Vraag afkoelingsperiode aan bij de rechtbank',
    'Bied het akkoord aan crediteurenklassen aan',
    'Vraag homologatie aan bij de rechtbank',
  ],
}

const clusterSlug = cluster.slug?.current || cluster.slug
const howToStepsForCluster = clusterSlug ? HOWTO_STEPS[clusterSlug] : undefined
if (howToStepsForCluster) {
  schemas.push({
    '@context': 'https://schema.org',
    '@type': 'HowTo',
    name: cluster.title,
    description: cluster.seo?.metaDescription || cluster.subtitle || '',
    step: howToStepsForCluster.map((text, i) => ({
      '@type': 'HowToStep',
      position: i + 1,
      name: text,
    })),
  })
}


const seoTitle = cluster.seo?.metaTitle || cluster.title
const seoDescription = cluster.seo?.metaDescription || cluster.tldr?.body?.slice(0, 160) || cluster.subtitle

const formatDate = (iso: string) => new Date(iso).toLocaleDateString('nl-NL', { day: 'numeric', month: 'long', year: 'numeric' })
---

<BaseLayout title={seoTitle} description={seoDescription} schemaJsonLd={schemas}>
  <article>
    <section class="bg-bg-tinted">
      <div class="max-w-content mx-auto px-4 md:px-8 py-12 md:py-16">
        <p class="text-tiny font-semibold uppercase tracking-wider text-text-secondary mb-3">
          {breadcrumbs.map((b, i) => (
            <>
              {i > 0 && ' › '}
              {i === breadcrumbs.length - 1 ? (
                <span>{b.name}</span>
              ) : (
                <a href={b.url} class="hover:text-text-accent">{b.name}</a>
              )}
            </>
          ))}
        </p>
        <h1 class="text-display font-extrabold text-text mb-3 tracking-tight">
          {cluster.title}
        </h1>
        {cluster.subtitle && (
          <p class="text-h3 text-text-secondary font-display font-semibold mb-6 italic">
            {cluster.subtitle}
          </p>
        )}
        <div class="text-tiny text-text-muted">
          {cluster.modifiedAt && <>Laatst bijgewerkt: {formatDate(cluster.modifiedAt)}</>}
          {cluster.author?.name && <> · Door {cluster.author.name}</>}
        </div>
      </div>
    </section>

    <div class="max-w-content mx-auto px-4 md:px-8 py-12">
      {cluster.tldr?.body && <TLDR heading={cluster.tldr.heading} body={cluster.tldr.body} />}

      {cluster.sections && cluster.sections.map((section: any) => (
        <section id={section.anchor} class="mt-16 scroll-mt-24">
          <h2 class="text-h2 font-bold mb-4 text-text">{section.heading}</h2>
          {section.answerCapsule && <AnswerCapsule text={section.answerCapsule} />}
          {section.body && (
            <div class="prose-content space-y-4 text-body text-text mt-6" set:html={renderPortableText(section.body)} />
          )}
        </section>
      ))}

      {cluster.faqs && cluster.faqs.length > 0 && <FAQAccordion faqs={cluster.faqs} />}

      {cluster.parentPillar && (
        <section class="mt-20 p-6 bg-bg-tinted rounded-lg">
          <h3 class="text-h4 font-semibold text-text mb-3">Lees ook over het bredere onderwerp</h3>
          <a href={`/praktijkgebieden/${cluster.parentPillar.slug}`} class="text-text-accent font-semibold no-underline hover:underline">
            {cluster.parentPillar.shortTitle} →
          </a>
        </section>
      )}
    </div>


      {cluster.relatedClusters && cluster.relatedClusters.length > 0 && (
        <section class="max-w-content mx-auto px-4 md:px-8 mt-12 mb-20">
          <h2 class="text-h2 font-bold mb-8 text-text">Verwante artikelen</h2>
          <div class="grid md:grid-cols-2 gap-4">
            {cluster.relatedClusters.map((r: any) => (
              <a href={`/clusters/${r.slug}`} class="block p-6 bg-bg-elevated border border-border rounded-lg hover:border-brand-primary no-underline transition">
                <div class="font-semibold text-text mb-2">{r.title}</div>
                {r.subtitle && <div class="text-small text-text-secondary">{r.subtitle}</div>}
              </a>
            ))}
          </div>
        </section>
      )}

    <CTABand />
  </article>
</BaseLayout>
