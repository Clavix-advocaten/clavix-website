---
import BaseLayout from '@layouts/BaseLayout.astro'
import CTABand from '@components/CTABand.astro'
import { getAllSectors } from '@lib/queries'
import { breadcrumbSchema } from '@lib/schema-markup'

const rawSectors = await getAllSectors()

// Pre-compute href per sector (vermijdt template literals in JSX attributes)
const sectors = (rawSectors || []).map((s: any) => ({
  ...s,
  href: '/sectoren/' + s.slug,
  excerpt: s.leadParagraph
    ? (s.leadParagraph.length > 140 ? s.leadParagraph.substring(0, 140) + '...' : s.leadParagraph)
    : '',
}))

const seoTitle = 'Sectoren — juridisch advies per industrie | Clavix Advocaten'
const seoDescription = 'Specialistisch juridisch advies voor uw sector: healthcare, horeca, tech, bouw, retail en vastgoed. Wij begrijpen de specifieke pijnpunten van uw industrie.'

const breadcrumbs = breadcrumbSchema([
  { name: 'Home', url: '/' },
  { name: 'Sectoren', url: '/sectoren' },
])

const collectionPage = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: seoTitle,
  description: seoDescription,
  url: 'https://clavix.nl/sectoren',
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: sectors.length,
    itemListElement: sectors.map((s: any, i: number) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: 'https://clavix.nl' + s.href,
      name: s.shortTitle,
    })),
  },
}

const schemas: any[] = [breadcrumbs, collectionPage]

// Icon mapping
const iconPaths: Record<string, string> = {
  hospital: 'M19 14l-7 7m0 0l-7-7m7 7V3',
  store: 'M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z',
  code: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4',
  construction: 'M14.121 14.121L19 19m-7-7l7-7m-7 7l-2.879 2.879M12 12L9.121 9.121',
  'shopping-bag': 'M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z',
  building: 'M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5',
}
---

<BaseLayout title={seoTitle} description={seoDescription} schemaJsonLd={schemas}>
  <nav class="max-w-content mx-auto px-4 md:px-8 pt-6 text-tiny text-text-secondary" aria-label="Breadcrumb">
    <a href="/" class="hover:text-text-accent no-underline">Home</a>
    <span class="mx-2">/</span>
    <span class="text-text">Sectoren</span>
  </nav>

  <section class="max-w-content mx-auto px-4 md:px-8 py-12 md:py-16">
    <h1 class="text-display font-extrabold text-text mb-4">Juridisch advies per sector</h1>
    <p class="text-lead text-text-secondary max-w-readable mb-6">
      Iedere sector heeft eigen pijnpunten. Wij specialiseren ons in industrieen waar wij de juridische context van binnen kennen, zodat advies direct relevant is voor uw situatie.
    </p>
  </section>

  <section class="max-w-content mx-auto px-4 md:px-8 pb-16">
    {sectors.length > 0 ? (
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {sectors.map((s: any) => (
          <a href={s.href} class="group block p-6 bg-bg-elevated border border-border rounded-lg hover:border-brand-primary transition no-underline">
            {s.iconKey && iconPaths[s.iconKey] && (
              <div class="w-12 h-12 mb-4 text-text-accent">
                <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" class="w-full h-full">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={iconPaths[s.iconKey]}/>
                </svg>
              </div>
            )}
            <h2 class="text-h3 font-bold text-text mb-2 group-hover:text-text-accent transition">{s.shortTitle}</h2>
            {s.subtitle && <p class="text-body text-text-secondary mb-3">{s.subtitle}</p>}
            {s.volumeStat && (
              <div class="inline-block px-2 py-1 bg-bg-tinted text-tiny text-text-muted rounded mb-3">
                {s.volumeStat}
              </div>
            )}
            {s.excerpt && <p class="text-small text-text-secondary">{s.excerpt}</p>}
            <div class="mt-4 text-small font-semibold text-text-accent">
              Meer over {s.shortTitle} &rarr;
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="text-center py-12 text-text-secondary">
        <p>Sectorpagina&apos;s worden binnenkort gepubliceerd. Neem voor sector-specifiek advies direct contact op.</p>
      </div>
    )}
  </section>

  <CTABand
    heading="Uw sector niet gezien?"
    description="Wij adviseren ondernemers in vrijwel elke sector. Bel direct voor een vrijblijvend kennismakingsgesprek."
  />
</BaseLayout>
